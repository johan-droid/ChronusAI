# ChronosAI Environment Variables

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/chronosai

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft Outlook
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

# ===========================================
# AI SERVICES
# ===========================================
DEEPSEEK_API_KEY=your-deepseek-api-key

# ===========================================
# CACHE & SESSIONS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
APP_ENV=development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ===========================================
# PRODUCTION OVERRIDES
# ===========================================
# Uncomment for production
# APP_ENV=production
# DIGITALOCEAN=true
# APP_URL=https://your-app-domain.ondigitalocean.app
# FRONTEND_URL=https://your-app-domain.ondigitalocean.app
# API_BASE_URL=https://your-app-domain.ondigitalocean.app/api
