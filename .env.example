# ChronosAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Use asyncpg driver for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chronosai
# Render / DO App Platform sets this as DATABASE_URL with postgres:// — the backend normalises it automatically.

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# All three keys auto-generate on first boot if left empty, but supply them in production
# to ensure values are stable across restarts/replicas.
SECRET_KEY=your-secret-key-min-32-chars          # openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-min-32-chars       # openssl rand -hex 32
ENCRYPTION_KEY=your-fernet-base64-key             # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===========================================
# AI SERVICES
# ===========================================
# Google Gemini — get a free key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini-3-flash-preview

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google Calendar — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft Outlook — https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/outlook/callback
MICROSOFT_TENANT_ID=common

# Zoom — https://marketplace.zoom.us/
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:8000/api/v1/auth/zoom/callback

# ===========================================
# SMTP / EMAIL REMINDERS
# ===========================================
# Gmail App Password recommended (Enable 2FA → create App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="ChronosAI <your-gmail@gmail.com>"

# Reminder defaults (can be overridden per-meeting in the UI)
REMINDER_MINUTES_BEFORE=15
# Comma-separated list of minutes before the meeting to send reminders:
REMINDER_SCHEDULE_MINUTES=1440,60,15

# ===========================================
# CORS & APP URLS
# ===========================================
APP_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# PRODUCTION OVERRIDES
# ===========================================
# Uncomment / set on Render or DigitalOcean:
# APP_ENV=production
# APP_URL=https://your-backend.onrender.com          # Used to auto-configure redirect URIs
# FRONTEND_URL=https://your-frontend.vercel.app
# RENDER=true                                         # Set automatically by Render
# RENDER_EXTERNAL_URL=https://your-backend.onrender.com  # Set automatically by Render
# DIGITALOCEAN=true
