# ChronosAI .gitignore
# Comprehensive ignore patterns for AI-Powered Meeting Scheduler

# ===========================================
# ENVIRONMENT & CONFIGURATION
# ===========================================
# Environment variables (NEVER commit these)
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# Production secrets and credentials
production.env
staging.env
credentials.json
service-account.json
api-keys.txt
secrets.txt
tokens.txt

# Configuration files with secrets
config/secrets.json
config/local.json
config/production.json
# NOTE: *.config.js / *.config.ts intentionally NOT ignored —
# vite.config.ts, tailwind.config.ts, postcss.config.js etc. must be committed

# Render-specific secrets
render-env.txt
render-secrets.json
*.render.env

# ===========================================
# PYTHON BACKEND
# ===========================================
# Virtual environments
venv/
.venv/
env/
envs/
.ENV/
env.bak/
venv.bak/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Exception: frontend TypeScript source lib is not a Python venv lib
!frontend/src/lib/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python testing and coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Test files output
# NOTE: test source files (test_*.py, *_test.py, tests/) should be committed
# Only ignore generated test output artifacts here
test-results/
test-reports/

# Python development tools
.dmypy.json
dmypy.json
.mypy/
.pyre/

# ===========================================
# PWA (PROGRESSIVE WEB APP)
# ===========================================
# PWA build artifacts (generated by vite-plugin-pwa)
public/workbox-*.js
public/sw.js
public/manifest.webmanifest

# PWA development files
dev-sw.js
dev-sw.js.map
sw.js.map
workbox-*.js.map

# PWA precache manifests
precache-manifest.*.js
precache-manifest.*.json

# Service worker registration
registerSW.js

# PWA offline fallback pages
offline.html
offline-fallback.html

# PWA icons and assets (if generated)
public/icons/generated/
public/icon-*.png
public/icon-*.ico
public/icon-*.svg

# PWA development cache
.pwa-cache/
sw-precache.log

# ===========================================
# NODE.JS FRONTEND
# ===========================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.terrazo/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Vite cache
.vite/

# Style linting cache
.stylelintcache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# ===========================================
# DATABASE & STORAGE
# ===========================================
# Database files
*.db
*.sqlite
*.sqlite3
scheduler.db
chronosai.db

# Database backups
*.sql
*.dump
*.backup

# Redis dump
dump.rdb

# ===========================================
# DOCKER & CONTAINERS
# ===========================================
# Docker volumes
docker/data/
docker/logs/
docker/tmp/

# Docker machine
.docker/

# ===========================================
# LOGS & MONITORING
# ===========================================
# Log files
*.log
logs/
log/
*.out
*.err

# Application logs
app.log
error.log
access.log
debug.log

# ===========================================
# IDE & EDITORS
# ===========================================
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains/IntelliJ
.idea/
*.iws
*.iml
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Kate
*.kate-swp

# TextMate
*.tmproj
*.tmproject

# ===========================================
# OPERATING SYSTEM
# ===========================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
*.lnk
*.url
*.desktop

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===========================================
# SECURITY & KEYS (CRITICAL - NEVER COMMIT)
# ===========================================
# Private keys and certificates
*.key
*.pem
*.crt
*.cert
*.p12
*.pfx
*.crl
*.csr

# Secret files
secrets/
.secrets.json
private/
private.key
id_rsa
id_rsa.pub
*.pem
*.key

# API keys and tokens
api_keys.txt
tokens.txt
credentials.json
service-account.json

# ===========================================
# TEMPORARY & BACKUP FILES
# ===========================================
# Temporary files
*.tmp
*.temp
temp/
tmp/
*.bak
*.backup
*.old
*.orig
*.rej

# Swap files
*.swp
*.swo
*~

# Generic lock files
# NOTE: package manager locks (yarn.lock, poetry.lock, Pipfile.lock) should be committed
# for reproducible builds — only ignore binary/temp lock files here
*.lck

# ===========================================
# AI/MODEL FILES
# ===========================================
# Model files (often large)
*.model
*.pkl
*.pickle
*.joblib
*.h5
*.pb
*.onnx

# Training data
data/
datasets/
training/
models/

# ===========================================
# DEPLOYMENT & INFRASTRUCTURE
# ===========================================
# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Kubernetes
*.kubeconfig
kubeconfig.yaml

# Serverless
.serverless/

# CloudFormation
*.cfn.yaml
*.cfn.json

# ===========================================
# CHRONOSAI SPECIFIC
# ===========================================
# Meeting scheduler specific
meeting-data/
calendar-cache/
oauth-tokens/
user-sessions/

# AI agent specific
agent-cache/
llm-cache/
chat-history/

# Render specific
render-build-cache/
render-logs/

# ===========================================
# PERFORMANCE & PROFILING
# ===========================================
# Profiling data
*.prof
*.profile
*.trace

# Benchmark results
benchmark/
benchmarks/
*.benchmark

# ===========================================
# DOCUMENTATION BUILD
# ===========================================
# Generated docs
docs/_build/
docs/build/
site/

# Sphinx
.sphinx/

# ===========================================
# MISC DEVELOPMENT
# ===========================================
# Local development files
.local/
local/
dev/
development/

# Test artifacts
test-results/
test-reports/
junit.xml
test-results.xml

# Backup files
backup/
backups/
*.backup
*.bak

# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Large media files
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.webm
*.mp3
*.wav
*.flac

# ===========================================
# EXCEPTIONS (FILES TO KEEP)
# ===========================================
# Keep important configuration files
!.env.example
!.gitkeep
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!SECURITY.md

# Keep documentation
!docs/
!docs/*.md
!docs/*.txt

# Keep deployment scripts
!scripts/
!deployment/
!tools/

# Keep Makefile
!Makefile
!makefile

# Keep Docker files
!Dockerfile*
!docker-compose*
!.dockerignore

# Keep backend models
!backend/app/models/