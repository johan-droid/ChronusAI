# App
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars
ENCRYPTION_KEY=your-fernet-base64-key
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://scheduler_user:password@localhost:5432/scheduler_db

# Google Gemini 3 Flash Preview (Native SDK)
# Get your free API key from https://aistudio.google.com/
OPENAI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini-3-flash-preview

# Google OAuth & Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/outlook/callback
MICROSOFT_TENANT_ID=common

# JWT
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
