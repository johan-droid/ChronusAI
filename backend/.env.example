# Backend Environment Variables
# Copy to backend/.env and fill in your values.
# NEVER commit the real .env to version control.

# ===========================================
# APP
# ===========================================
APP_ENV=development
# Auto-generated on first boot if empty — supply stable values in production:
SECRET_KEY=your-secret-key-min-32-chars
ENCRYPTION_KEY=your-fernet-base64-key
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ===========================================
# DATABASE
# ===========================================
# Use asyncpg driver prefix for async SQLAlchemy (backend normalises postgres:// automatically)
DATABASE_URL=postgresql+asyncpg://scheduler_user:password@localhost:5432/scheduler_db

# Supabase (free tier) — set these when using Supabase instead of local Postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key  # backend-only, never expose to frontend
# Optional: point DATABASE_URL at Supabase Postgres (service role password), sslmode required
# DATABASE_URL=postgresql+asyncpg://postgres:<service_role_password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ===========================================
# AI — Google Gemini
# ===========================================
# Free key: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini-3-flash-preview

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google OAuth & Calendar API — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft OAuth — https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/outlook/callback
MICROSOFT_TENANT_ID=common

# Zoom OAuth — https://marketplace.zoom.us/
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:8000/api/v1/auth/zoom/callback

# ===========================================
# SMTP / EMAIL REMINDERS
# ===========================================
# Gmail App Password recommended (requires 2FA → create App Password at myaccount.google.com)
# See docs/SMTP_SETUP.md for full instructions and examples.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="ChronosAI Notifications <your-gmail@gmail.com>"

# ===========================================
# REMINDER SCHEDULING
# ===========================================
# Single legacy value (used when REMINDER_SCHEDULE_MINUTES is not set)
REMINDER_MINUTES_BEFORE=15
# Multi-step schedule: comma-separated minutes before meeting (e.g. 1 day, 1 hr, 15 min)
REMINDER_SCHEDULE_MINUTES=1440,60,15

# ===========================================
# PRODUCTION — Docker Host / Cloud VM / App Platform
# ===========================================
# APP_ENV=production
# APP_URL=https://api.yourdomain.com
# BACKEND_PUBLIC_URL=https://api.yourdomain.com
# DIGITALOCEAN=true

# Frontend / CORS
FRONTEND_URL=https://chronos-ai-theta.vercel.app
# CSV or JSON array (e.g. ["https://foo","https://bar"]) accepted
CORS_ORIGINS=https://chronos-ai-theta.vercel.app,https://yourdomain.com

# Optional uptime keep-alive (enable only if you want periodic health pings)
# SELF_PING_URL defaults to APP_URL/BACKEND_PUBLIC_URL when available
SELF_PING_ENABLED=false
# SELF_PING_URL=https://api.yourdomain.com
SELF_PING_INTERVAL=30
