# Heroku environment variables example for backend
# Set these in your Heroku app: heroku config:set KEY=value --app your-app-name

# Auto-provisioned by Heroku Postgres addon - DO NOT set manually
# DATABASE_URL=postgres://...

# AI
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.herokuapp.com/api/v1/auth/google/callback

# Microsoft OAuth (https://portal.azure.com/)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=https://your-backend.herokuapp.com/api/v1/auth/outlook/callback

# Security (auto-generated in app.json, or set manually)
JWT_SECRET_KEY=
ENCRYPTION_KEY=
SECRET_KEY=

# Frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-frontend.herokuapp.com

# App
APP_ENV=production
