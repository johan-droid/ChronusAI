# Production Environment Variables Template
# Use this as a reference for production deployments

# ===========================================
# REQUIRED FOR ALL DEPLOYMENTS
# ===========================================
APP_ENV=production
SECRET_KEY=your-secret-key-min-32-chars
ENCRYPTION_KEY=your-fernet-base64-key
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Choose ONE based on your deployment platform:

# Render (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
RENDER=true

# Railway (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
PORT=8000

# Supabase (PostgreSQL)
# Prefer Supabase transaction pooler host and require SSL.
# User is often postgres.[PROJECT_REF] for pooler connections.
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?ssl=require
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# DigitalOcean (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
DIGITALOCEAN=true

# Vercel (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
VERCEL=true

# Cloudflare Workers (D1 - SQLite)
DATABASE_URL=sqlite+aiosqlite:///./scheduler.db
CLOUDFLARE=true

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app

# ===========================================
# AI SERVICES
# ===========================================
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini-3-flash-preview
OPENAI_API_KEY=your-openai-api-key

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google OAuth & Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/v1/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=https://your-backend-domain.com/api/v1/auth/outlook/callback
MICROSOFT_TENANT_ID=common

# Zoom OAuth
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=https://your-backend-domain.com/api/v1/auth/zoom/callback

# ===========================================
# EMAIL SERVICES
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="ChronosAI Notifications <your-gmail@gmail.com>"

# ===========================================
# REMINDER CONFIGURATION
# ===========================================
REMINDER_MINUTES_BEFORE=15
REMINDER_SCHEDULE_MINUTES=1440,60,15
