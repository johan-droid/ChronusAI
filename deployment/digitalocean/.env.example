# DigitalOcean Deployment Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ===========================================
# DOMAIN & INFRASTRUCTURE
# ===========================================
DOMAIN=your-domain.com

# PostgreSQL (used by docker-compose)
POSTGRES_PASSWORD=your-secure-password-here

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key
JWT_SECRET_KEY=your-jwt-secret-key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key

# ===========================================
# AI — Google Gemini
# ===========================================
# Free key: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini-3-flash-preview

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft — https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# Zoom — https://marketplace.zoom.us/
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ===========================================
# SMTP / EMAIL REMINDERS
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="ChronosAI <your-gmail@gmail.com>"

# Reminder schedule (comma-separated minutes before meeting)
REMINDER_SCHEDULE_MINUTES=1440,60,15

# ===========================================
# APP URLS
# ===========================================
APP_ENV=production
DIGITALOCEAN=true
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
