# Frontend Environment Variables
# Copy this file to frontend/.env.local and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser bundle.
# NEVER commit the real .env.local to version control.

# ===========================================
# API
# ===========================================
# Points to your FastAPI backend.
# Development default: proxied through Vite dev server or direct.
VITE_API_URL=http://localhost:8000/api/v1

# Production (Render backend example):
# VITE_API_URL=https://your-backend.onrender.com/api/v1

# ===========================================
# APP METADATA (optional overrides)
# ===========================================
# Shown in the browser tab and PWA manifest
VITE_APP_NAME=ChronosAI
VITE_APP_VERSION=1.0.0

# ===========================================
# FEATURE FLAGS (optional)
# ===========================================
# Set to "true" to enable verbose console logging in development
VITE_DEBUG=false
